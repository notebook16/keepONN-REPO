# Cooldown log (IMEI,timestamp) — upserted after each successful SET
# COMMAND_LOG_CSV=data/comman_log.csv
# Fired command log (append-only: imei,timestamp for each successful SET)
# FIRED_COMMAND_CSV=data/fired_command.csv

# Manual override CSV to ignore specific IMEIs (columns: imei,reason)
# OVERRIDE_CSV=data/override.csv

# Ignore IMEIs if latest command_requests row is:
# command='discharging' AND command_status=false AND created_at > cutoff
# COMMAND_REQUEST_MIN_CREATED_AT=2026-06-30T18:29:59Z

# Min minutes before re-commanding the same IMEI (default 10)
# COOLDOWN_MINUTES=10

# Seconds between daemon cycles (default 60)
# LOOP_INTERVAL_SEC=60

# Seconds between Redis SETs within one cycle (default 0.10)
# SET_INTERVAL_SEC=0.10

# SCAN tuning
# SCAN_COUNT=1000
# PIPELINE_BATCH_SIZE=500

# SET payload fields
# DEFAULT_DEVICE_TYPE=Teltonika-TFT100
# PLATFORM=heyev

# Preview only — no Redis writes, no CSV updates
# DRY_RUN=1
