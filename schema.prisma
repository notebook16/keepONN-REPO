generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model backup_service_models {
  request_id      String    @id @db.VarChar(255)
  bucket_name     String    @db.VarChar(80)
  start_timestamp BigInt
  end_timestamp   BigInt?
  object_url      String?
  status          String    @db.VarChar(50)
  error_msg       String?
  created_at      DateTime? @db.Timestamptz(6)
  updated_at      DateTime? @db.Timestamptz(6)
  vehicle_no      String    @db.VarChar(100)
  created_by      BigInt?

  @@index([end_timestamp], map: "idx_backup_service_models_end_timestamp")
  @@index([start_timestamp], map: "idx_backup_service_models_start_timestamp")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model batch_qc_checks {
  qc_id          BigInt         @id @default(autoincrement())
  org_id         BigInt
  batch_cd       String         @db.VarChar(100)
  priority       String
  is_active      Boolean        @default(true)
  qc_desc        String
  qc_sql         String
  expected_count BigInt
  created_at     DateTime?      @default(now()) @db.Timestamptz(6)
  created_by     BigInt?
  check_name     String         @db.VarChar(50)
  batch_qcs      batch_qcs      @relation(fields: [batch_cd], references: [batch_qc_cd], onDelete: NoAction, onUpdate: NoAction, map: "fk_batch_qc_checks_batch_cd")
  organisations  organisations  @relation(fields: [org_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_batch_qcs_org")
  users          users?         @relation(fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_batch_qcs_user")
  batch_qc_logs  batch_qc_logs?
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model batch_qc_logs {
  qc_id           BigInt          @id
  batch_cd        String          @db.VarChar(100)
  status          String
  message         String?
  created_by      BigInt?         @default(1)
  start_at        DateTime        @db.Timestamptz(6)
  end_at          DateTime        @db.Timestamptz(6)
  org_id          BigInt
  organisations   organisations   @relation(fields: [org_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  batch_qcs       batch_qcs       @relation(fields: [batch_cd], references: [batch_qc_cd], onDelete: NoAction, onUpdate: NoAction, map: "fk_batch_qc_logs_batch_cd")
  batch_qc_checks batch_qc_checks @relation(fields: [qc_id], references: [qc_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_batch_qc_logs_qc_id")
}

model batch_qcs {
  batch_qc_cd     String            @id @db.VarChar(100)
  batch_qc_name   String            @db.VarChar(100)
  exec_order      BigInt
  email           String            @db.VarChar(100)
  is_enabled      Boolean
  org_id          BigInt
  batch_qc_checks batch_qc_checks[]
  batch_qc_logs   batch_qc_logs[]
  organisations   organisations     @relation(fields: [org_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model batteries {
  id                         BigInt    @id(map: "batteries_pkey1") @default(autoincrement())
  organisation_id            BigInt
  product_id                 BigInt
  lot_number                 String?
  status                     String?
  bms                        String?
  oem                        String?
  cell_oem                   String?
  model_name                 String?
  battery_voltage            Decimal?  @db.Decimal
  battery_capacity           Decimal?  @db.Decimal
  cell_type                  String?
  cell_brand                 String?
  cell_manufacturer          String?
  cell_voltage               Decimal?  @db.Decimal
  charge_time_peak           Decimal?  @db.Decimal
  discharge_time_peak        Decimal?  @db.Decimal
  battery_with_thermal_paste Boolean?  @default(false)
  active_balancer_in_bms     Boolean?  @default(false)
  nominal_capacity           Decimal?  @db.Decimal
  nominal_cycle_count        BigInt?
  max_range                  Decimal?  @db.Decimal
  max_distance               Decimal?  @db.Decimal
  battery_serial_number      String?
  rated_battery_pack_cycles  BigInt?
  max_speed                  Decimal?  @db.Decimal
  created_at                 DateTime? @db.Timestamptz(6)
  updated_at                 DateTime? @db.Timestamptz(6)
}

model centers {
  center_id                       BigInt                         @id @default(autoincrement())
  center_name                     String                         @unique(map: "idx_unique_center_name")
  address                         String?
  city                            String?
  state                           String?
  pincode                         String?
  manager_id                      BigInt?
  created_at                      DateTime?                      @db.Timestamptz(6)
  updated_at                      DateTime?                      @db.Timestamptz(6)
  geo_location_lat                Decimal                        @db.Decimal(10, 6)
  geo_location_lng                Decimal                        @db.Decimal(10, 6)
  center_region                   String                         @db.VarChar(50)
  type2_sheet_id                  String
  invoice_center_address          String
  invoice_gst_number              String
  invoice_state_code              String
  invoice_center_mobile           String
  org_id                          BigInt?
  center_code                     String                         @db.VarChar(50)
  dealer_id                       BigInt?
  created_by                      BigInt?
  city_id                         BigInt?
  region_id                       BigInt?
  cities                          cities?                        @relation(fields: [city_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users_centers_created_byTousers users?                         @relation("centers_created_byTousers", fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  partners                        partners?                      @relation(fields: [dealer_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  organisations                   organisations?                 @relation(fields: [org_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  regions                         regions?                       @relation(fields: [region_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users_centers_manager_idTousers users?                         @relation("centers_manager_idTousers", fields: [manager_id], references: [id], map: "fk_centers_manager")
  collection_cash_balance         collection_cash_balance[]
  collection_request              collection_request[]
  collection_trans                collection_trans[]
  collections                     collections[]
  inv_locations                   inv_locations[]
  iot_raw                         iot_raw[]
  iot_summ                        iot_summ[]
  loan_applications               loan_applications[]
  loan_terms                      loan_terms[]
  rpt_lms_payment_mnly            rpt_lms_payment_mnly[]
  rpt_lms_payment_mnly_stage      rpt_lms_payment_mnly_stage[]
  sales                           sales[]
  srv_tickets                     srv_tickets[]
  xref_collection_scrap_center    xref_collection_scrap_center[]

  @@unique([center_code, org_id], map: "uq_centers_center_code_org_id")
}

model cities {
  id        BigInt    @id @default(autoincrement())
  name      String    @db.VarChar(100)
  state     String    @db.VarChar(100)
  district  String?   @db.VarChar(100)
  country   String    @default("India") @db.VarChar(100)
  latitude  Decimal?  @db.Decimal(10, 7)
  longitude Decimal?  @db.Decimal(10, 7)
  centers   centers[]

  @@unique([name, state, district], map: "uk_cities_name_state_district")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model collection_bank_trans {
  id                                            BigInt            @id @default(autoincrement())
  org_id                                        BigInt?
  collection_trans_id                           BigInt?
  date                                          DateTime          @db.Timestamptz(6)
  value_date                                    DateTime          @db.Timestamptz(6)
  narration                                     String
  cheque_ref_no                                 String
  deposit_amount                                Decimal?          @db.Decimal(10, 2)
  withdraw_amount                               Decimal?          @db.Decimal(10, 2)
  closing_balance                               Decimal?          @db.Decimal(10, 2)
  sys_mode                                      String
  created_at                                    DateTime?         @default(now()) @db.Timestamptz(6)
  created_by                                    BigInt
  matched_at                                    DateTime?         @db.Timestamptz(6)
  matched_by                                    BigInt?
  collection_trans                              collection_trans? @relation(fields: [collection_trans_id], references: [trans_id], onDelete: NoAction, onUpdate: NoAction)
  users_collection_bank_trans_created_byTousers users             @relation("collection_bank_trans_created_byTousers", fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users_collection_bank_trans_matched_byTousers users?            @relation("collection_bank_trans_matched_byTousers", fields: [matched_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  organisations                                 organisations?    @relation(fields: [org_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model collection_cash_balance {
  id            BigInt        @id @default(autoincrement())
  org_id        BigInt
  center_id     BigInt
  user_id       BigInt
  day           DateTime      @db.Date
  net_amount    Decimal       @default(0) @db.Decimal(12, 2)
  created_at    DateTime      @default(now()) @db.Timestamptz(6)
  cash_in       Decimal       @default(0) @db.Decimal(12, 2)
  hand_in       Decimal       @default(0) @db.Decimal(12, 2)
  bank_out      Decimal       @default(0) @db.Decimal(12, 2)
  hand_out      Decimal       @default(0) @db.Decimal(12, 2)
  scrap_in      Decimal       @default(0) @db.Decimal(12, 2)
  scrap_out     Decimal       @default(0) @db.Decimal(12, 2)
  centers       centers       @relation(fields: [center_id], references: [center_id], onDelete: NoAction, onUpdate: NoAction)
  organisations organisations @relation(fields: [org_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users         users         @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([org_id, center_id, user_id, day], map: "unique_cash_balance")
  @@index([day], map: "idx_ccb_day")
}

model collection_comments {
  collection_comment_id BigInt        @id @default(autoincrement())
  org_id                BigInt
